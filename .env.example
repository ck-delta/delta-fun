# ──────────────────────────────────────────────────────────────
# Backend (copy to backend/.env for local dev; set as secrets on Vercel)
# ──────────────────────────────────────────────────────────────
# Required: OpenRouter API key powering the AI signal via Claude Sonnet 4.6
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Optional: override the model slug (defaults to anthropic/claude-sonnet-4.6)
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6

# Optional: Delta Exchange API base (default: https://api.india.delta.exchange/v2)
DELTA_API_BASE=https://api.india.delta.exchange/v2

# Optional: Referer + title sent to OpenRouter for attribution
OPENROUTER_REFERER=https://delta-fun.vercel.app

# Local dev only — the backend listens on this port.
PORT=3001

# ──────────────────────────────────────────────────────────────
# Frontend (copy to frontend/.env for local dev)
# ──────────────────────────────────────────────────────────────
# Empty in production (same-origin via Vercel rewrites). In dev, Vite proxies
# /api to localhost:3001 — leave blank or point at an explicit URL.
VITE_API_URL=
